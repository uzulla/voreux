{
  "name": "voreux-workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "e2e": "pnpm --filter @voreux/example-cfe-jp e2e",
    "e2e:self-heal": "pnpm --filter @voreux/example-cfe-jp e2e:self-heal",
    "e2e:swagger-editor": "pnpm --filter @voreux/example-swagger-editor e2e",
    "e2e:swagger-editor:self-heal": "pnpm --filter @voreux/example-swagger-editor e2e:self-heal",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check .",
    "typecheck": "pnpm --filter voreux exec tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9"
  }
}
