{
  "title": "GitHub link happy path",
  "steps": [
    {
      "type": "setViewport",
      "width": 1280,
      "height": 720,
      "deviceScaleFactor": 1,
      "isMobile": false,
      "hasTouch": false,
      "isLandscape": true
    },
    {
      "type": "navigate",
      "url": "https://cfe.jp/",
      "assertedEvents": [
        {
          "type": "navigation",
          "url": "https://cfe.jp/",
          "title": "uzulla aka Junichi Ishida's Profile"
        }
      ]
    },
    {
      "type": "click",
      "target": "main",
      "selectors": [
        ["aria/GitHub"],
        ["a.github"],
        ["xpath//html/body/div[1]/div/section[1]/div/a[2]"],
        ["pierce/a.github"]
      ],
      "offsetY": 49,
      "offsetX": 40.5
    }
  ]
}
