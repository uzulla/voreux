# LLM Provider (pick one provider, and set both the API key and STAGEHAND_MODEL)
OPENAI_API_KEY=sk-...
STAGEHAND_MODEL=openai/gpt-4o
# ANTHROPIC_API_KEY=sk-ant-...
# STAGEHAND_MODEL=anthropic/claude-3-7-sonnet-latest

STAGEHAND_CACHE_DIR=.cache/stagehand-e2e
E2E_SCREENSHOTS_DIR=screenshots
E2E_RECORDINGS_DIR=recordings
E2E_BASELINES_DIR=baselines

# Browser path
# Voreux uses chrome-launcher internally, so the important thing is that Stagehand can see
# a real Chrome/Chromium executable path.
# If Chrome/Chromium is already installed system-wide, point CHROME_PATH at that binary.
# If not, you can fetch a Playwright-managed Chromium binary with:
#   pnpm run install:chromium
# and then point CHROME_PATH at the downloaded executable.
# Linux:  CHROME_PATH=/home/<username>/.cache/ms-playwright/chromium-XXXX/chrome-linux64/chrome
# macOS:  CHROME_PATH=/Users/<username>/Library/Caches/ms-playwright/chromium-XXXX/chrome-mac/Chromium.app/Contents/MacOS/Chromium
# WSL2:   Same as Linux. Note: --no-sandbox is required on WSL2 and is already handled by the framework.
# CHROME_PATH=
